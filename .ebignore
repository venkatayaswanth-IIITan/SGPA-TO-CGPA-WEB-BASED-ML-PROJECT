# Elastic Beanstalk deploy ignore file
# Excludes files that should NOT be uploaded to EB

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
env/
.env/
ENV/

# Local dev
*.log
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
.gitattributes

# IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Old app.py (EB uses application.py)
# Keep both for safety — EB will use application.py
