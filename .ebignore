# Elastic Beanstalk deploy ignore file
# Excludes files that should NOT be uploaded to EB

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
env/
.env/
ENV/

# Local dev
*.log
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
.gitattributes

# IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Training script & outputs — not needed on the server
train_model.py
model_evaluation.png

# NOTE: model.pkl and Student_Performance1.csv are intentionally
# NOT ignored — they must be included in the EB deployment bundle.
